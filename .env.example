# Provider type: "openai" (default) or "anthropic"
# - "openai": translates Claude-format requests to OpenAI-compatible backends
# - "anthropic": forwards requests directly to an Anthropic-compatible backend (no translation)
PROVIDER="openai"

# Required: API key for the backend provider
# When PROVIDER=openai: this is your OpenAI API key (or your OpenAI-compatible provider's key)
# When PROVIDER=anthropic: this is your Anthropic API key (or your Anthropic-compatible provider's key)
PROVIDER_API_KEY="sk-your-provider-api-key-here"

# Optional: API key for client authentication
# If set, clients must provide this exact API key (via x-api-key or Authorization header) to use the proxy
CLIENT_API_KEY="your-expected-client-api-key"

# Backend base URL (varies by provider type)
# When PROVIDER=openai: your OpenAI-compatible endpoint (default: https://api.openai.com/v1)
PROVIDER_BASE_URL="https://api.openai.com/v1"

# When PROVIDER=anthropic: your Anthropic-compatible endpoint (default: https://api.anthropic.com/v1)
ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"

# Optional: Model mappings (BIG, MIDDLE, and SMALL models)
BIG_MODEL="gpt-4o"           # Used for Claude opus requests (or default mapping)
MIDDLE_MODEL="gpt-4o"        # Used for Claude sonnet requests (falls back to BIG_MODEL)
SMALL_MODEL="gpt-4o-mini"    # Used for Claude haiku requests

# Optional: Server settings
HOST="0.0.0.0"
PORT="8082"
LOG_LEVEL="INFO"
# DEBUG, INFO, WARNING, ERROR, CRITICAL

# Optional: Performance settings
MAX_TOKENS_LIMIT="4096"
MIN_TOKENS_LIMIT="4096"      # Minimum tokens limit (helps avoid errors with thinking models)
REQUEST_TIMEOUT="90"
MAX_RETRIES="2"

# Legacy env var names (still supported for backward compatibility):
# OPENAI_API_KEY  → same as PROVIDER_API_KEY
# OPENAI_BASE_URL → same as PROVIDER_BASE_URL
# ANTHROPIC_API_KEY → same as CLIENT_API_KEY

# Examples for other providers:

# For Azure OpenAI (if OpenAI is not available in your region):
# PROVIDER=openai
# PROVIDER_API_KEY="your-azure-api-key"
# PROVIDER_BASE_URL="https://your-resource-name.openai.azure.com/openai/deployments/your-deployment-name"
# AZURE_API_VERSION="2024-03-01-preview"
# BIG_MODEL="gpt-4"
# MIDDLE_MODEL="gpt-4"
# SMALL_MODEL="gpt-35-turbo"

# For local models (like Ollama):
# PROVIDER=openai
# PROVIDER_API_KEY="dummy-key"   # Required but can be any value for local models
# PROVIDER_BASE_URL="http://localhost:11434/v1"
# BIG_MODEL="llama3.1:70b"
# MIDDLE_MODEL="llama3.1:70b"
# SMALL_MODEL="llama3.1:8b"

# For Anthropic-compatible APIs (e.g., DeepSeek Anthropic-format endpoint):
# PROVIDER=anthropic
# PROVIDER_API_KEY="sk-your-anthropic-compatible-key"
# ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
# BIG_MODEL="claude-sonnet-4-20250514"
# MIDDLE_MODEL="claude-sonnet-4-20250514"
# SMALL_MODEL="claude-haiku-3-5-20241022"

# Note: If you get "unsupported_country_region_territory" errors,
# consider using Azure OpenAI or a local model setup instead.
